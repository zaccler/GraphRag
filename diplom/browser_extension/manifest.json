{
  "manifest_version": 3,
  "name": "GraphRAG Manager",
  "version": "0.1.0",
  "description": "Chat and manager panel for the local GraphRAG API.",
  "action": {
    "default_title": "GraphRAG Manager",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8099/*",
    "http://localhost:8099/*"
  ]
}
