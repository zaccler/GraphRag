LLM_RATE_MAX_PER_MINUTE=10
EMBEDDING_RATE_MAX_PER_MINUTE=20
LLM_RATE_MAX_SIMULTANEOUS=1
EMBEDDING_RATE_MAX_SIMULTANEOUS=1
ASK_TIMEOUT_SEC=30
