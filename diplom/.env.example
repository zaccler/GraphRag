# Copy this file to .env and fill your own values.
# Do not commit .env.

# LLM / embeddings
OPENAI_API_KEY=your_llm_api_key_here
EMBEDDING_API_KEY=your_embedding_api_key_here
BASE_URL=https://api.mistral.ai/v1
EMBEDDING_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL_NAME=mistral-small-latest
EMBEDDER_MODEL_NAME=mistral-embed
TOKENIZER_MODEL=gpt-4o-mini
EMBEDDER_DIM=1024

# Local paths
RAW_LIT_DIR=raw/lit
GENERATED_DIR=raw/generated
DOCS_REGISTRY_PATH=xdt/rpo/docs_registry.json
PACKAGE_REGISTRY_PATH=xdt/rpo/packages.txt
REGISTRY_PATH=xdt/rpo/docs_registry.json
DOCS_RAW_DIR=raw/lit/docs
PACKAGE_RAW_DIR=raw/lit/packages
DHB_DIR=dhb/data
STORAGE_DIR=storage/ragu_graph
CHAT_LOG_PATH=dhb/data/chat_logs.jsonl

# Dgraph
# Use localhost:9080 for local Python launch, dgraph-alpha:9080 inside docker-compose.
DGRAPH_ADDRESS=localhost:9080

# SMTP email login codes
# For Gmail use App Password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_symbol_app_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
AUTH_CODE_TTL_SEC=600
AUTH_CODE_LENGTH=6

# Google Sheets
# Chat logs: Apps Script must implement doPost and doGet.
GOOGLE_SHEETS_LOG_WEBHOOK_URL=https://script.google.com/macros/s/your_chat_script_id/exec
GOOGLE_SHEETS_LOG_READ_URL=https://script.google.com/macros/s/your_chat_script_id/exec
# Text database mirror: Apps Script doPost endpoint.
GOOGLE_SHEETS_TEXT_DB_WEBHOOK_URL=https://script.google.com/macros/s/your_text_db_script_id/exec
TEXT_DB_SHEET_LOG_PATH=dhb/data/text_db_rows.jsonl
TEXT_DB_SHEET_MAX_TEXT_CHARS=45000

# Parsing limits
PYTHON_DOCS_ROOT=https://docs.python.org/3.12/
CRAWL_MAX_PAGES=300
CRAWL_DELAY_SEC=0.15
PACKAGE_MAX_VERSIONS=30
GITHUB_MAX_RELEASES=10
CHUNK_MAX_SIZE=4000

# Request timeouts and rate limits
LLM_TIMEOUT_SEC=120
EMBEDDING_TIMEOUT_SEC=120
LLM_CONNECT_TIMEOUT_SEC=15
EMBEDDING_CONNECT_TIMEOUT_SEC=15
LLM_RATE_MAX_PER_MINUTE=10
EMBEDDING_RATE_MAX_PER_MINUTE=20
LLM_RATE_MAX_SIMULTANEOUS=1
EMBEDDING_RATE_MAX_SIMULTANEOUS=1
LLM_RETRY_TIMES_SEC=10,30,60,120,300,600,900,1200
EMBEDDING_RETRY_TIMES_SEC=5,15,30,60,120,300
ASK_TIMEOUT_SEC=90
SEARCH_TOP_K=8
FAST_CONTEXT_LIMIT=6
FAST_CONTEXT_CHAR_LIMIT=12000

# External data resource pool
XDT_RESOURCE_POOL_PATH=xdt/pul/resources.json
XDT_HTTP_TIMEOUT_SEC=30
XDT_HTTP_RETRIES=2
GITHUB_TOKEN=