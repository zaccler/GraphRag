SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
AUTH_CODE_TTL_SEC=600
AUTH_CODE_LENGTH=6

